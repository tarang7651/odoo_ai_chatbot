<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_chat_session_tree" model="ir.ui.view">
        <field name="name">ai.chat.session.tree</field>
        <field name="model">ai.chat.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="create_date"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_ai_chat_session_form" model="ir.ui.view">
        <field name="name">ai.chat.session.form</field>
        <field name="model">ai.chat.session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                    </group>
                    <notebook>
                        <page string="Messages">
                            <field name="message_ids">
                                <list>
                                    <field name="role"/>
                                    <field name="content"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_chat_session" model="ir.actions.act_window">
        <field name="name">AI Chat Sessions</field>
        <field name="res_model">ai.chat.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ai_chatbot_root" name="AI Chatbot" sequence="10" groups="base.group_system"/>
    <menuitem id="menu_ai_chat_sessions" name="Sessions" parent="menu_ai_chatbot_root" action="action_ai_chat_session" sequence="10"/>
</odoo>
