<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule for regular users: Only see own sessions -->
        <record id="ai_chat_session_user_rule" model="ir.rule">
            <field name="name">AI Chat Session: Own records</field>
            <field name="model_id" ref="model_ai_chat_session"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <!-- Rule for regular users: Only see own messages -->
        <record id="ai_chat_message_user_rule" model="ir.rule">
            <field name="name">AI Chat Message: Own records</field>
            <field name="model_id" ref="model_ai_chat_message"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <!-- Rule for admins: See all sessions -->
        <record id="ai_chat_session_admin_rule" model="ir.rule">
            <field name="name">AI Chat Session: All records</field>
            <field name="model_id" ref="model_ai_chat_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>
        
        <!-- Rule for admins: See all messages -->
        <record id="ai_chat_message_admin_rule" model="ir.rule">
            <field name="name">AI Chat Message: All records</field>
            <field name="model_id" ref="model_ai_chat_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>
    </data>
</odoo>
